{
  "name": "llm-trace-viewer",
  "version": "0.1.1",
  "private": true,
  "description": "A browser extension to view LLM request trace logs (JSONL format) in a beautiful web UI",
  "keywords": [
    "chrome-extension",
    "jsonl",
    "llm",
    "log",
    "trace",
    "viewer",
    "ai",
    "debug"
  ],
  "license": "MIT",
  "author": "wisetwo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wugao123456/llm-trace-viewer.git"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build:ui && npm run build:icons && npm run build:manifest",
    "build:ui": "vite build",
    "build:icons": "npx tsx scripts/generate-icons.ts",
    "build:manifest": "cp manifest.json dist/extension/manifest.json",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.272",
    "@types/node": "^22.0.0",
    "lit": "^3.3.2",
    "tsx": "^3.14.0",
    "typescript": "^5.6.0",
    "vite": "^4.5.0"
  }
}
